{
  "name": "@tempad-dev/extension",
  "version": "0.18.14",
  "private": true,
  "description": "Open handoff tooling for Figma",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build && pnpm run build:rewrite && pnpm run build:readme",
    "build:rewrite": "esbuild ./rewrite/figma.ts --outfile=./dist/figma.js --bundle --format=iife && cp ./public/rules/figma.legacy.json ./dist/figma.json && cp ./public/rules/figma.legacy.json ./dist/figma.comply.json",
    "build:readme": "tsx ./build/readme.ts",
    "zip": "wxt zip",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --fix --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "check:rewrite": "tsx ./scripts/check-rewrite.ts",
    "check:worker-sandbox": "tsx ./scripts/check-worker-sandbox.ts",
    "screenshots": "tsx ./scripts/screenshots.ts",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts && pnpm run check:worker-sandbox",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:headed": "vitest run --config vitest.browser.config.ts --browser.headless=false",
    "test:setup": "pnpm exec playwright install chromium",
    "test:coverage": "vitest run --config vitest.node.config.ts --coverage",
    "format": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --ignore-path ../../.gitignore --check"
  },
  "dependencies": {
    "@tempad-dev/plugins": "workspace:^0.6.2",
    "@tempad-dev/shared": "workspace:^0.1.0",
    "@vueuse/core": "^14.3.0",
    "overlayscrollbars": "^2.16.0",
    "p-wait-for": "^6.0.0",
    "stringify-object": "^6.0.0",
    "svgson": "^5.3.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@figma/plugin-typings": "^1.130.0",
    "@types/node": "^24.13.2",
    "@types/prismjs": "^1.26.6",
    "@types/stringify-object": "^4.0.5",
    "@vitest/browser-playwright": "4.1.9",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "comment-mark": "^2.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "playwright": "^1.61.1",
    "prismjs": "^1.30.0",
    "proper-lockfile": "^4.1.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "4.1.9",
    "vue-tsc": "^3.3.6",
    "wxt": "^0.20.27",
    "zod": "^4.4.3"
  }
}
